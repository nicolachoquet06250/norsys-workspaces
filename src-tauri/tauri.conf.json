{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "dev-workspace-manager",
  "version": "0.4.5",
  "identifier": "com.shadow.dev-workspace-manager",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "dev-workspace-manager",
        "visible": false,
        "width": 800,
        "height": 600
      },
      {
        "label": "splashscreen",
        "title": "Chargement",
        "url": "splashscreen.html",
        "width": 420,
        "height": 280,
        "resizable": false,
        "decorations": false,
        "alwaysOnTop": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/nicolachoquet06250/norsys-workspaces/releases/latest/download/latest.json"
      ],
      "dialog": true,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDc4MTk5Q0M0OTg2RTEzMkMKUldRc0UyNll4SndaZUxxQ2RLaXR2THFuSUZ6QVpXSDllTExQQnl0bmdPN1UwVlk1T3pzc3F0T0oK"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi", "deb", "rpm", "appimage"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "wix": {
        "language": ["en-US", "fr-FR"]
      },
      "nsis": {
        "languages": ["French", "English"],
        "displayLanguageSelector": true
      }
    },
    "createUpdaterArtifacts": true
  }
}
